[Unit]
Description=HN Read The Room FastHTML app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=exedev
WorkingDirectory=/home/exedev/hn-readtheroom
Environment=PORT=8000
Environment=UVICORN_WORKERS=2
ExecStart=/home/exedev/hn-readtheroom/.venv/bin/uvicorn app:app --host 0.0.0.0 --port ${PORT} --workers ${UVICORN_WORKERS}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
